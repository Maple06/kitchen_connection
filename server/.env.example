# App Mode
# Options: deployment | local_azure | local_xampp
APP_MODE=local_xampp

# Azure SQL (use when APP_MODE = local_azure or deployment)
DB_SERVER=your-server.database.windows.net
DB_USER=your_db_user
DB_PASSWORD=YOUR_AZURE_SQL_PASSWORD
DB_NAME=kitchenconnection
DB_PORT=1433

# MySQL / XAMPP (use when APP_MODE = local_xampp)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=kitchenconnection

# App
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret

# Email (Brevo SMTP)
BREVO_USER=your@email.com
BREVO_PASS=your_brevo_smtp_key
