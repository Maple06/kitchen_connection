# App Mode
# Options: local | deployment
# - local: running on your machine
# - deployment: Cloud Run / remote DB (enables SSL in db.js)
APP_MODE=local

# MySQL (Local)
DB_SERVER=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=kitchenconnection

# MySQL (Aiven / Remote)
# APP_MODE=deployment
# DB_SERVER=your-aiven-host.aivencloud.com
# DB_PORT=15530
# DB_USER=avnadmin
# DB_PASSWORD=YOUR_AIVEN_PASSWORD
# DB_NAME=defaultdb

# Optional alias (supported by some scripts):
# DB_HOST=localhost

# App
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret

# Email (Brevo SMTP)
BREVO_USER=your@email.com
BREVO_PASS=your_brevo_smtp_key
