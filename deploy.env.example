# GCP Project
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=your-gcp-project-region
GCP_REGISTRY=gcr.io

# Note:
# - If you deploy Cloud Run to a different project than where the image lives,
#   you must grant the Cloud Run service agent permission to pull the image.

# Cloud Run Service Names
SERVICE_CLIENT=your-service-name
SERVICE_SERVER=your-service-api-name

# Docker Image Names
IMAGE_CLIENT=your-docker-image-name
IMAGE_SERVER=your-docker-api-image-name

# Server env vars file (relative to repo root)
SERVER_ENV_FILE=env.yaml
