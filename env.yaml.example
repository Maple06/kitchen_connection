# Cloud Run env vars template (do NOT commit env.yaml with real secrets)
# Copy this file to env.yaml and fill the values.

APP_MODE: "deployment"

# MySQL (Aiven)
DB_SERVER: "your-aiven-host.aivencloud.com"
DB_PORT: "15530"
DB_USER: "avnadmin"
DB_PASSWORD: "YOUR_AIVEN_PASSWORD"
DB_NAME: "defaultdb"

# App
FRONTEND_URL: "https://your-client-url.run.app"
JWT_SECRET: "your_long_random_secret"

# Email (Brevo SMTP)
BREVO_USER: "your@email.com"
BREVO_PASS: "your_brevo_smtp_key"

# Optional
# PORT: "5000"
# GOOGLE_CLOUD_PROJECT: "your-gcp-project-id"
